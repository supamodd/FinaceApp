<Window x:Class="FinanceApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FinanceApp.Views"
        Title="ФинХелпер"
        Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9"
        Icon="/Views/finicon.ico">
    <!-- Стили кнопок меню -->
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20 0 0 0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Боковое меню -->
        <Border Background="#2C3E50" Padding="10">
            <StackPanel>
                <Image Source="/logo.png" Width="180" Height="80" Margin="15 30 15 40" HorizontalAlignment="Center"/>
                <Button Content="🏠 Dashboard" Style="{StaticResource MenuButton}" Click="Dashboard_Click"/>
                <Button Content="📋 Операции" Style="{StaticResource MenuButton}" Click="Transactions_Click"/>
                <Button Content="🏷️ Категории" Style="{StaticResource MenuButton}" Click="Categories_Click"/>
                <Button Content="📊 Отчёты" Style="{StaticResource MenuButton}" Click="Reports_Click"/>
                <!-- ✅ НОВАЯ КНОПКА СЕМЬЯ -->
                <Button Content="👨‍👩‍👧 Семья" Style="{StaticResource MenuButton}" Click="Family_Click"/>
                <Button Content="💰 Бюджеты" Style="{StaticResource MenuButton}" Click="Budgets_Click"/>
                <Separator Margin="20 40 20 20" Background="#34495E"/>
                <Button Content="🚪 Выйти" Background="#E74C3C" Foreground="White" Height="50" Click="Logout_Click"/>
            </StackPanel>
        </Border>
        <!-- Основная область -->
        <Grid Grid.Column="1">
            <!-- Шапка с мини-профилем -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Height="80" VerticalAlignment="Top" Margin="0,-5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Margin="30 0 0 0"/>
                    <local:MiniProfileControl Margin="717,5,10,5"/>
                </Grid>
            </Border>
            <!-- Контент (страницы) -->
            <Frame x:Name="ContentFrame" Grid.Column="0" Margin="0,80,0,0" NavigationUIVisibility="Hidden" Background="#F8F9FA"/>
        </Grid>
    </Grid>
</Window>