<UserControl x:Class="FinanceApp.Views.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="340" Opacity="0">

    <UserControl.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" X="360"/>
    </UserControl.RenderTransform>

    <Border x:Name="ToastBorder" CornerRadius="14" Padding="18 14" Margin="0 0 0 10"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Иконка -->
            <TextBlock x:Name="txtIcon" Grid.Column="0" FontSize="22" 
                       VerticalAlignment="Center" Margin="0 0 14 0"/>

            <!-- Текст -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="txtTitle" FontSize="14" FontWeight="SemiBold"
                           Foreground="#F1F5F9"/>
                <TextBlock x:Name="txtMessage" FontSize="12" 
                           Foreground="#94A3B8" TextWrapping="Wrap"
                           Margin="0 2 0 0"/>
            </StackPanel>

            <!-- Кнопка закрытия -->
            <Button Grid.Column="2" Content="✕" Width="24" Height="24" FontSize="10"
                    Background="Transparent" BorderThickness="0" 
                    Foreground="#64748B" Cursor="Hand"
                    VerticalAlignment="Top"
                    Click="BtnClose_Click"/>
        </Grid>
    </Border>
</UserControl>