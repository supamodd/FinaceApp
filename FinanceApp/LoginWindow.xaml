<Window x:Class="FinanceApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ФинХелпер — Вход" 
        Height="600" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/finicon.ico">

    <Border CornerRadius="24" Padding="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0B1A" Offset="0"/>
                <GradientStop Color="#1E1A3A" Offset="0.6"/>
                <GradientStop Color="#151229" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <!-- Декоративные световые пятна -->
            <Ellipse Width="300" Height="300" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-80,0" Opacity="0.08">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B5CF6" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="250" Height="250" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-60,0,0,-60" Opacity="0.06">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#A78BFA" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Кнопка закрытия -->
            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,16,20,0" Width="36" Height="36"
                    FontSize="14" Foreground="#64748B" Background="Transparent" 
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click"/>

            <!-- Основной контент -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">

                <!-- Логотип -->
                <Image Source="/logo.png" Height="70" Margin="0 0 0 10" HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- Заголовок -->
                <TextBlock Text="Добро пожаловать" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0 0 0 6"/>
                <TextBlock Text="Войдите в свой аккаунт" 
                           FontSize="14" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0 0 0 36"/>

                <!-- Поле логина -->
                <TextBlock Text="ЛОГИН" Style="{StaticResource Label}" Margin="4 0 0 6"/>
                <TextBox x:Name="txtLogin" Style="{StaticResource ModernTextBox}"/>

                <!-- Поле пароля -->
                <TextBlock Text="ПАРОЛЬ" Style="{StaticResource Label}" Margin="4 20 0 6"/>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBox}"/>

                <!-- Кнопка Войти -->
                <Button Content="Войти" 
                        Style="{StaticResource PrimaryButton}"
                        Margin="0 32 0 12"
                        Click="BtnLogin_Click"/>

                <!-- Кнопка Регистрация -->
                <Button Content="Создать аккаунт" 
                        Style="{StaticResource GhostButton}"
                        Click="BtnRegister_Click"/>

                <!-- Ошибка -->
                <TextBlock x:Name="txtError" 
                           Foreground="{StaticResource RedBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0 16 0 0" 
                           TextWrapping="Wrap"
                           FontSize="13"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
