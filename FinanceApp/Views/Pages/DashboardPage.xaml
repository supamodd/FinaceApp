<UserControl x:Class="FinanceApp.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Карточки -->
                <RowDefinition Height="Auto"/>
                <!-- Фильтры -->
                <RowDefinition Height="Auto"/>
                <!-- PieChart -->
                <RowDefinition Height="Auto"/>
                <!-- Новый: CartesianChart -->
                <RowDefinition Height="Auto"/>
                <!-- Последние операции -->
            </Grid.RowDefinitions>

            <!-- Карточки баланса -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="#2C3E50" CornerRadius="10" Margin="8" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Общий баланс" Foreground="White" FontSize="17"/>
                        <TextBlock x:Name="txtBalance" Text="0 ₽" Foreground="White" FontSize="36" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#4CAF50" CornerRadius="10" Margin="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Доходы" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="txtIncome" Text="+0 ₽" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F44336" CornerRadius="10" Margin="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Расходы" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="txtExpense" Text="-0 ₽" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Фильтры -->
            <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0 20 0 10">
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="cmbPeriod" Width="210" Height="42" FontSize="14" Margin="0 0 15 0"
                              SelectionChanged="CmbPeriod_SelectionChanged">
                        <ComboBoxItem Content="Этот месяц" Tag="ThisMonth" IsSelected="True"/>
                        <ComboBoxItem Content="Последние 30 дней" Tag="Last30Days"/>
                        <ComboBoxItem Content="Последние 3 месяца" Tag="Last3Months"/>
                        <ComboBoxItem Content="Всё время" Tag="AllTime"/>
                        <ComboBoxItem Content="Выбрать период..." Tag="Custom"/>
                    </ComboBox>

                    <ComboBox x:Name="cmbChartMode" Width="220" Height="42" FontSize="14" Margin="0 0 15 0"
                              SelectionChanged="CmbChartMode_SelectionChanged">
                        <ComboBoxItem Content="Доходы vs Расходы" IsSelected="True"/>
                        <ComboBoxItem Content="По категориям"/>
                    </ComboBox>

                    <CheckBox x:Name="chkPercent" Content="В процентах"
                              VerticalAlignment="Center" FontSize="14" Margin="15 0 0 0"
                              Checked="ChkPercent_Changed" Unchecked="ChkPercent_Changed"/>
                </StackPanel>
            </Border>

            <!-- Кастомный период -->
            <StackPanel x:Name="CustomPeriodPanel" Grid.Row="1" Orientation="Horizontal" Margin="0 5 0 15" Visibility="Collapsed">
                <DatePicker x:Name="dpFrom" Width="170" Margin="0 0 10 0" SelectedDateChanged="DpFrom_SelectedDateChanged"/>
                <DatePicker x:Name="dpTo" Width="170" SelectedDateChanged="DpTo_SelectedDateChanged"/>
            </StackPanel>

            <!-- PieChart -->
            <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20" Margin="0 0 0 20">
                <lc:PieChart x:Name="pieChart" Height="340" LegendPosition="Right"/>
            </Border>

            <!-- Новый график: Динамика по месяцам -->
            <Border Grid.Row="3" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20" Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Динамика по месяцам" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 10"/>
                    <lc:CartesianChart x:Name="monthlyChart" Height="320"/>
                </StackPanel>
            </Border>

            <!-- Последние операции -->
            <GroupBox Grid.Row="4" Header="Последние операции" Margin="0 10 0 0" FontSize="16">
                <DataGrid x:Name="dgLastTransactions" AutoGenerateColumns="False" IsReadOnly="True" Height="260">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="90"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="110"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="180"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>