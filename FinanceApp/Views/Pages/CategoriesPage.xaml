<UserControl x:Class="FinanceApp.Views.Pages.CategoriesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="32 28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 20">
            <TextBlock Text="🏷️ Категории" Style="{StaticResource PageTitle}" VerticalAlignment="Center"/>
            <Button Content="➕ Добавить категорию" 
                    Style="{StaticResource SuccessButton}"
                    Margin="30 0 0 0" Padding="24 0"
                    Click="BtnAdd_Click"/>
        </StackPanel>

        <!-- Categories Table -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}">
            <DataGrid x:Name="dgCategories" 
                      Style="{StaticResource ModernDataGrid}"
                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                      CellStyle="{StaticResource ModernDataGridCell}"
                      RowStyle="{StaticResource ModernDataGridRow}"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="280"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="140"/>
                    <DataGridTemplateColumn Header="Цвет" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="32" Height="32" CornerRadius="8" 
                                        Background="{Binding Color}"
                                        BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
