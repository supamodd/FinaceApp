<UserControl x:Class="FinanceApp.Views.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="360" Opacity="0">

    <UserControl.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" X="380"/>
    </UserControl.RenderTransform>

    <Border x:Name="ToastBorder" CornerRadius="14" Padding="18 14" Margin="0 0 0 10"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Иконка -->
                <TextBlock x:Name="txtIcon" Grid.Column="0" FontSize="22" 
                           VerticalAlignment="Center" Margin="0 0 14 0"/>

                <!-- Текст -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitle" FontSize="14" FontWeight="SemiBold"
                               Foreground="#F1F5F9"/>
                    <TextBlock x:Name="txtMessage" FontSize="12" 
                               Foreground="#94A3B8" TextWrapping="Wrap"
                               Margin="0 2 0 0"/>
                </StackPanel>

                <!-- Кнопка закрытия -->
                <Button Grid.Column="2" Content="✕" Width="24" Height="24" FontSize="10"
                        Background="Transparent" BorderThickness="0" 
                        Foreground="#64748B" Cursor="Hand"
                        VerticalAlignment="Top"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- Кнопки подтверждения (скрыты по умолчанию) -->
            <StackPanel x:Name="ConfirmPanel" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0 12 0 0"
                        Visibility="Collapsed">
                <Button x:Name="btnCancel" Content="Отмена" 
                        Width="90" Height="34" FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="8" Background="#15FFFFFF" 
                                    BorderBrush="#30FFFFFF" BorderThickness="1"
                                    Padding="12 6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="btnConfirm" Content="Да, удалить" 
                        Width="110" Height="34" FontSize="12" FontWeight="SemiBold"
                        Foreground="White" Margin="8 0 0 0"
                        Cursor="Hand" Click="BtnConfirm_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="8" Padding="12 6">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F87171" Offset="0"/>
                                        <GradientStop Color="#DC2626" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>