<UserControl x:Class="FinanceApp.Views.MiniProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="14" Padding="12 8" Cursor="Hand"
            Background="{StaticResource GlassWhiteBrush}"
            BorderBrush="{StaticResource GlassBorderBrush}" 
            BorderThickness="1" Width="195">

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Avatar circle -->
            <Border Width="40" Height="40" CornerRadius="20" 
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="2"
                    Background="{StaticResource GlassWhiteBrush}">
                <Border CornerRadius="18" ClipToBounds="True">
                    <Image x:Name="imgAvatar" Stretch="UniformToFill"/>
                </Border>
            </Border>

            <!-- Name & login -->
            <StackPanel Margin="12 0 0 0" VerticalAlignment="Center">
                <TextBlock x:Name="txtFullName" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock x:Name="txtLogin" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
            <Button Content="✏️" Width="65" Height="40"
                    Background="Transparent" BorderThickness="0" FontSize="15"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Cursor="Hand" Click="BtnEdit_Click"/>

            <!-- Edit button -->
        </StackPanel>
    </Border>
</UserControl>
