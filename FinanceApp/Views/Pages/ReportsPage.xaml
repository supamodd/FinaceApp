<UserControl x:Class="FinanceApp.Views.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фильтр по периоду -->
        <GroupBox Grid.Row="0" Header="Период отчёта" Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal" Margin="15">
                <StackPanel Margin="0 0 30 0">
                    <TextBlock Text="С:" Margin="0 0 0 5"/>
                    <DatePicker x:Name="dpFrom" Width="180"/>
                </StackPanel>

                <StackPanel Margin="0 0 30 0">
                    <TextBlock Text="По:" Margin="0 0 0 5"/>
                    <DatePicker x:Name="dpTo" Width="180"/>
                </StackPanel>

                <Button Content="🔍 Показать отчёт" 
                        Background="#2196F3" Foreground="White" FontSize="16"
                        Padding="25 10" Margin="20 25 0 0"
                        Click="BtnShowReport_Click"/>

                <Button Content="📤 Экспорт в Excel" 
                        Background="#4CAF50" Foreground="White" FontSize="16"
                        Padding="25 10" Margin="15 25 0 0"
                        Click="BtnExportExcel_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- Итоги -->
        <Grid Grid.Row="1" Margin="0 0 0 15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Background="#4CAF50" CornerRadius="8" Margin="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="Доходы" Foreground="White" FontSize="16"/>
                    <TextBlock x:Name="txtTotalIncome" Text="+0 ₽" Foreground="White" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F44336" CornerRadius="8" Margin="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="Расходы" Foreground="White" FontSize="16"/>
                    <TextBlock x:Name="txtTotalExpense" Text="-0 ₽" Foreground="White" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#2C3E50" CornerRadius="8" Margin="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="Баланс" Foreground="White" FontSize="16"/>
                    <TextBlock x:Name="txtTotalBalance" Text="0 ₽" Foreground="White" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Таблица отчёта -->
        <DataGrid x:Name="dgReport" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="90"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="110"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="180"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>