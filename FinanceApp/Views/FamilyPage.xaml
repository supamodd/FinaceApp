<Page x:Class="FinanceApp.Views.FamilyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Семья"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32 28">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="👨‍👩‍👧 Моя Семья" Style="{StaticResource PageTitle}" Margin="0 0 0 28"/>

                <!-- ═══ Если пользователь НЕ в семье ═══ -->
                <StackPanel x:Name="NotInFamilyPanel">
                    <TextBlock Text="Вы пока не состоите ни в одной семье" 
                               FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" Margin="0 0 0 28"/>

                    <!-- Создать семью -->
                    <Border Style="{StaticResource GlassCard}" Margin="0 0 0 20" MaxWidth="600" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Создать новую семью" Style="{StaticResource SectionTitle}" Margin="0 0 0 14"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="FamilyNameBox" Style="{StaticResource ModernTextBox}" 
                                         Width="320" Margin="0 0 16 0"/>
                                <Button Content="Создать" Style="{StaticResource PrimaryButton}" 
                                        Padding="28 0" Click="CreateFamily_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Присоединиться по коду -->
                    <Border Style="{StaticResource GlassCard}" MaxWidth="600" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Присоединиться по коду" Style="{StaticResource SectionTitle}" Margin="0 0 0 14"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="InviteCodeBox" Style="{StaticResource ModernTextBox}" 
                                         Width="320" Margin="0 0 16 0"/>
                                <Button Content="Присоединиться" Style="{StaticResource SuccessButton}" 
                                        Padding="24 0" Click="JoinByCode_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ Если пользователь В СЕМЬЕ ═══ -->
                <StackPanel x:Name="InFamilyPanel" Visibility="Collapsed">
                    <TextBlock x:Name="FamilyNameText" FontSize="26" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0 0 0 6"/>
                    <TextBlock x:Name="RoleText" FontSize="15" 
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0 0 0 24"/>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 24">
                        <Button Content="📨 Пригласить" Style="{StaticResource PrimaryButton}" 
                                Padding="24 0" Margin="0 0 12 0" Click="Invite_Click"/>
                        <Button Content="🚪 Покинуть семью" Style="{StaticResource DangerButton}" 
                                Padding="24 0" Click="LeaveFamily_Click"/>
                    </StackPanel>

                    <TextBlock Text="Участники семьи" Style="{StaticResource SectionTitle}" Margin="0 0 0 14"/>

                    <Border Style="{StaticResource GlassCard}" Padding="0">
                        <DataGrid x:Name="MembersGrid"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  CellStyle="{StaticResource ModernDataGridCell}"
                                  RowStyle="{StaticResource ModernDataGridRow}"
                                  Height="340"
                                  CanUserAddRows="False"
                                  MouseRightButtonUp="MembersGrid_MouseRightButtonUp">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Имя" Binding="{Binding User.FullName}" Width="*"/>
                                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="130"/>
                                <DataGridTextColumn Header="Дата вступления" Binding="{Binding JoinedAt, StringFormat=dd.MM.yyyy}" Width="160"/>
                            </DataGrid.Columns>

                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Изменить роль" Click="ChangeRole_Click"/>
                                    <MenuItem Header="Исключить из семьи" Click="RemoveMember_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
