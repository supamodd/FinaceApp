<UserControl x:Class="FinanceApp.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="32 28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ Balance Cards ═══ -->
            <Grid Grid.Row="0" Margin="0 0 0 24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="18" Margin="0 0 10 0" Padding="28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="#6D28D9" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="#8B5CF6"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Общий баланс" Foreground="#D4BFFF" FontSize="15" FontWeight="Medium"/>
                        <TextBlock x:Name="txtBalance" Text="0 ₽" Foreground="White" FontSize="38" FontWeight="Bold" Margin="0 8 0 0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="18" Margin="6 0" Padding="24"
                        Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0 0 10 0"
                                    Background="{StaticResource GreenBrush}" Opacity="0.15"/>
                            <TextBlock Text="↑" Foreground="{StaticResource GreenBrush}" FontSize="22" FontWeight="Bold" 
                                       Margin="-36,6,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Доходы" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0 12 0 4"/>
                        <TextBlock x:Name="txtIncome" Text="+0 ₽" Foreground="{StaticResource GreenBrush}" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="18" Margin="6 0 0 0" Padding="24"
                        Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0 0 10 0"
                                    Background="{StaticResource RedBrush}" Opacity="0.15"/>
                            <TextBlock Text="↓" Foreground="{StaticResource RedBrush}" FontSize="22" FontWeight="Bold" 
                                       Margin="-36,6,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Расходы" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0 12 0 4"/>
                        <TextBlock x:Name="txtExpense" Text="-0 ₽" Foreground="{StaticResource RedBrush}" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Filters ═══ -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="18" Margin="0 0 0 12">
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="cmbPeriod" Width="210" Height="42" FontSize="14" Margin="0 0 15 0"
                              SelectionChanged="CmbPeriod_SelectionChanged">
                        <ComboBoxItem Content="Этот месяц" Tag="ThisMonth" IsSelected="True"/>
                        <ComboBoxItem Content="Последние 30 дней" Tag="Last30Days"/>
                        <ComboBoxItem Content="Последние 3 месяца" Tag="Last3Months"/>
                        <ComboBoxItem Content="Всё время" Tag="AllTime"/>
                        <ComboBoxItem Content="Выбрать период..." Tag="Custom"/>
                    </ComboBox>

                    <ComboBox x:Name="cmbChartMode" Width="220" Height="42" FontSize="14" Margin="0 0 15 0"
                              SelectionChanged="CmbChartMode_SelectionChanged">
                        <ComboBoxItem Content="Доходы vs Расходы" IsSelected="True"/>
                        <ComboBoxItem Content="По категориям"/>
                    </ComboBox>

                    <CheckBox x:Name="chkPercent" Content="В процентах"
                              VerticalAlignment="Center" FontSize="14" Margin="15 0 0 0"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Checked="ChkPercent_Changed" Unchecked="ChkPercent_Changed"/>
                </StackPanel>
            </Border>

            <!-- Custom period -->
            <StackPanel x:Name="CustomPeriodPanel" Grid.Row="2" Orientation="Horizontal" Margin="0 0 0 15" Visibility="Collapsed">
                <DatePicker x:Name="dpFrom" Width="170" Margin="0 0 10 0" SelectedDateChanged="DpFrom_SelectedDateChanged"/>
                <DatePicker x:Name="dpTo" Width="170" SelectedDateChanged="DpTo_SelectedDateChanged"/>
            </StackPanel>

            <!-- ═══ Pie Chart — тёмный фон ═══ -->
            <Border Grid.Row="3" Style="{StaticResource GlassCard}" Margin="0 0 0 20">
                <lc:PieChart x:Name="pieChart" Height="340" LegendPosition="Right"
                             Background="Transparent"/>
            </Border>

            <!-- ═══ Monthly Chart — тёмный фон ═══ -->
            <Border Grid.Row="4" Style="{StaticResource GlassCard}" Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Динамика по месяцам" Style="{StaticResource SectionTitle}" Margin="0 0 0 14"/>
                    <lc:CartesianChart x:Name="monthlyChart" Height="320"
                                       Background="Transparent"/>
                </StackPanel>
            </Border>

            <!-- ═══ Recent Transactions ═══ -->
            <Border Grid.Row="5" Style="{StaticResource GlassCard}">
                <StackPanel>
                    <TextBlock Text="Последние операции" Style="{StaticResource SectionTitle}" Margin="0 0 0 16"/>
                    <DataGrid x:Name="dgLastTransactions" 
                              Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              CellStyle="{StaticResource ModernDataGridCell}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              Height="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="120"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="180"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>