<UserControl x:Class="FinanceApp.Views.Pages.BudgetsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="32 28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 20">
                <TextBlock Text="💰 Бюджеты по категориям" Style="{StaticResource PageTitle}" VerticalAlignment="Center"/>
                <Button Content="+ Добавить бюджет" 
                        Style="{StaticResource SuccessButton}"
                        Margin="30 0 10 0" Padding="24 0"
                        Click="AddBudget_Click"/>
                <Button Content="✏️ Редактировать" 
                        Style="{StaticResource PrimaryButton}"
                        Margin="0 0 10 0" Padding="20 0"
                        Click="EditBudget_Click"/>
                <Button Content="🗑 Удалить" 
                        Style="{StaticResource DangerButton}"
                        Padding="20 0"
                        Click="DeleteBudget_Click"/>
            </StackPanel>

            <!-- Budgets Table -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}">
                <DataGrid x:Name="dgBudgets"
                          Style="{StaticResource ModernDataGrid}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          CellStyle="{StaticResource ModernDataGridCell}"
                          RowStyle="{StaticResource ModernDataGridRow}"
                          CanUserSortColumns="True"
                          RowHeight="56"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Budget.Category.Name}" Width="220"/>
                        <DataGridTextColumn Header="Лимит" 
                                Binding="{Binding Budget.PlannedAmount, StringFormat={}{0:N0} ₽}" 
                                Width="150"/>
                        <DataGridTemplateColumn Header="Прогресс" Width="300">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ProgressBar Value="{Binding ProgressPercent}" 
                                                 Height="22" 
                                                 Background="#15FFFFFF"
                                                 Foreground="{StaticResource AccentBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Потрачено / Лимит" 
                                Binding="{Binding SpentInfo}" 
                                Width="180"/>
                        <DataGridTextColumn Header="Статус" 
                                Binding="{Binding Status}" 
                                Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>