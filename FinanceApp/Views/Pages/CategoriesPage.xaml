<UserControl x:Class="FinanceApp.Views.Pages.CategoriesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопка -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 15">
            <TextBlock Text="🏷️ Категории" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="➕ Добавить категорию" 
                    Background="#4CAF50" Foreground="White" FontSize="16"
                    Padding="20 8" Margin="30 0 0 0"
                    Click="BtnAdd_Click"/>
        </StackPanel>

        <!-- Таблица категорий -->
        <DataGrid x:Name="dgCategories" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="120"/>
                <DataGridTemplateColumn Header="Цвет" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Rectangle Width="30" Height="30" Fill="{Binding Color}" RadiusX="4" RadiusY="4"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>