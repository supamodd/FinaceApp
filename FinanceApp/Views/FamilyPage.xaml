<Page x:Class="FinanceApp.Views.FamilyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Семья">
    <Grid Margin="30">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="👨‍👩‍👧 Моя Семья" FontSize="32" FontWeight="Bold" Margin="0,0,0,30"/>

            <!-- Если пользователь НЕ в семье -->
            <StackPanel x:Name="NotInFamilyPanel">
                <TextBlock Text="Вы пока не состоите ни в одной семье" FontSize="18" Foreground="#666" Margin="0,0,0,20"/>
                <TextBlock Text="Создать новую семью" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                    <TextBox x:Name="FamilyNameBox" Width="300" Height="45" FontSize="18"
                             VerticalContentAlignment="Center" Margin="0,0,15,0"/>
                    <Button Content="Создать семью" Width="180" Height="45" FontSize="17"
                            Click="CreateFamily_Click"/>
                </StackPanel>
                <TextBlock Text="Присоединиться по коду" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="InviteCodeBox" Width="300" Height="45" FontSize="18"
                             VerticalContentAlignment="Center" Margin="0,0,15,0"/>
                    <Button Content="Присоединиться" Width="180" Height="45" FontSize="17"
                            Click="JoinByCode_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Если пользователь В СЕМЬЕ -->
            <StackPanel x:Name="InFamilyPanel" Visibility="Collapsed">
                <TextBlock x:Name="FamilyNameText" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock x:Name="RoleText" FontSize="18" Foreground="#555" Margin="0,0,0,25"/>

                <Button Content="📨 Пригласить в семью" Width="250" Height="50" FontSize="18"
                        Click="Invite_Click" Margin="0,0,0,20"/>

                <Button Content="🚪 Покинуть семью" Width="200" Height="45"
                        Click="LeaveFamily_Click" Margin="0,0,0,25"/>

                <TextBlock Text="Участники семьи" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- DataGrid с контекстным меню -->
                <DataGrid x:Name="MembersGrid"
                          AutoGenerateColumns="False"
                          Height="320"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          RowHeight="34"
                          ColumnWidth="Auto"
                          MouseRightButtonUp="MembersGrid_MouseRightButtonUp">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Имя" Binding="{Binding User.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="110"/>
                        <DataGridTextColumn Header="Дата вступления" Binding="{Binding JoinedAt, StringFormat=dd.MM.yyyy}" Width="140"/>
                    </DataGrid.Columns>

                    <!-- Контекстное меню (ПКМ) -->
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Изменить роль" Click="ChangeRole_Click"/>
                            <MenuItem Header="Исключить из семьи" Click="RemoveMember_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>