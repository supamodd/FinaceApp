<Window x:Class="FinanceApp.Views.AddBudgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый бюджет" Height="480" Width="500"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#151229" Offset="0"/>
                <GradientStop Color="#1E1A3A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="32 28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Grid Grid.Row="0" Margin="0 0 0 24">
                <TextBlock Text="Добавить бюджет" Style="{StaticResource PageTitle}"/>
                <Button Content="✕" HorizontalAlignment="Left" Width="47" Height="36"
                        FontSize="14" Foreground="{StaticResource TextMutedBrush}" 
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="Cancel_Click" Margin="389,2,0,2"/>
            </Grid>

            <!-- Category -->
            <StackPanel Grid.Row="1" Margin="0 0 0 16">
                <TextBlock Text="КАТЕГОРИЯ" Style="{StaticResource Label}"/>
                <ComboBox x:Name="cmbCategory" Height="44" FontSize="15"/>
            </StackPanel>

            <!-- Limit -->
            <StackPanel Grid.Row="2" Margin="0 0 0 16">
                <TextBlock Text="ЛИМИТ (₽)" Style="{StaticResource Label}"/>
                <TextBox x:Name="txtLimit" Style="{StaticResource ModernTextBox}" Text="10000"/>
            </StackPanel>

            <!-- Month + Year -->
            <Grid Grid.Row="3" Margin="0 0 0 24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0 0 8 0">
                    <TextBlock Text="МЕСЯЦ" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="cmbMonth" Height="44" FontSize="15"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8 0 0 0">
                    <TextBlock Text="ГОД" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="cmbYear" Height="44" FontSize="15"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource GhostButton}" 
                        Width="120" Margin="0 0 12 0" Click="Cancel_Click"/>
                <Button Content="Сохранить бюджет" Style="{StaticResource SuccessButton}" 
                        Width="180" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
