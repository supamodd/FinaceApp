<Window x:Class="FinanceApp.Views.AddBudgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый бюджет" Height="420" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добавить бюджет на месяц" FontSize="22" FontWeight="Bold" Margin="0 0 0 20"/>

        <!-- Категория -->
        <StackPanel Grid.Row="1" Margin="0 0 0 15">
            <TextBlock Text="Категория" FontSize="14" Margin="0 0 0 5"/>
            <ComboBox x:Name="cmbCategory" Height="40" FontSize="15"/>
        </StackPanel>

        <!-- Сумма лимита -->
        <StackPanel Grid.Row="2" Margin="0 0 0 15">
            <TextBlock Text="Лимит (₽)" FontSize="14" Margin="0 0 0 5"/>
            <TextBox x:Name="txtLimit" Height="40" FontSize="18" Text="10000"/>
        </StackPanel>

        <!-- Месяц и год -->
        <Grid Grid.Row="3" Margin="0 0 0 25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0 0 10 0">
                <TextBlock Text="Месяц" FontSize="14" Margin="0 0 0 5"/>
                <ComboBox x:Name="cmbMonth" Height="40" FontSize="15"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10 0 0 0">
                <TextBlock Text="Год" FontSize="14" Margin="0 0 0 5"/>
                <ComboBox x:Name="cmbYear" Height="40" FontSize="15"/>
            </StackPanel>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Width="110" Height="45" Margin="0 0 15 0"
                    Click="Cancel_Click" Background="#95A5A6" Foreground="White"/>
            <Button Content="Сохранить бюджет" Width="160" Height="45"
                    Click="Save_Click" Background="#27AE60" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>