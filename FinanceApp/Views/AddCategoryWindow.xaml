<Window x:Class="FinanceApp.Views.AddCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая категория" Height="368" Width="424"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="Название категории" Margin="0 0 0 5"/>
            <TextBox x:Name="txtName" Height="40" FontSize="16"/>

            <TextBlock Text="Тип" Margin="0 15 0 5"/>
            <ComboBox x:Name="cmbType" Height="40">
                <ComboBoxItem Content="Расход" IsSelected="True"/>
                <ComboBoxItem Content="Доход"/>
            </ComboBox>

            <!-- Выбор цвета (HEX + превью) -->
            <TextBlock Text="Цвет" Margin="0 15 0 5"/>
            <StackPanel Orientation="Horizontal">
                <Border x:Name="colorPreview" Width="60" Height="40" CornerRadius="6" BorderBrush="#CCCCCC" BorderThickness="2"/>
                <TextBox x:Name="txtColor" Width="120" Height="40" Margin="15 0 0 0" 
                         Text="#FF5722" FontSize="16" TextChanged="TxtColor_TextChanged"/>
                <TextBlock Text="(HEX)" Margin="10 10 0 0" Foreground="#666"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 40 0 0">
                <Button Content="Отмена" Width="110" Height="45" Margin="0 0 10 0" Click="BtnCancel_Click"/>
                <Button Content="Добавить категорию" Width="170" Height="45" 
                        Background="#4CAF50" Foreground="White" Click="BtnSave_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>