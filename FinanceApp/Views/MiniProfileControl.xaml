<UserControl x:Class="FinanceApp.Views.MiniProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#F8F9FA" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Width="318">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Аватар -->
            <Border Width="48" Height="48" CornerRadius="24" BorderBrush="#CCCCCC" BorderThickness="2">
                <Image x:Name="imgAvatar" Stretch="UniformToFill"/>
            </Border>

            <!-- Информация -->
            <StackPanel Margin="12 0 0 0" VerticalAlignment="Center">
                <TextBlock x:Name="txtFullName" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock x:Name="txtLogin" FontSize="13" Foreground="#666666"/>
            </StackPanel>

            <!-- Кнопка редактирования -->
            <Button Content="✏️" Width="54" Height="54" Margin="20 0 0 0"
                    Background="Transparent" BorderThickness="0" FontSize="18"
                    Click="BtnEdit_Click"/>
        </StackPanel>
    </Border>
</UserControl>