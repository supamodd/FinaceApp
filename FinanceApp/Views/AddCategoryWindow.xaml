<Window x:Class="FinanceApp.Views.AddCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая категория" Height="440" Width="460"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#151229" Offset="0"/>
                <GradientStop Color="#1E1A3A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="32 28">
            <StackPanel>
                <!-- Title -->
                <Grid Margin="0 0 0 24">
                    <TextBlock Text="Новая категория" Style="{StaticResource PageTitle}"/>
                    <Button Content="✕" HorizontalAlignment="Left" Width="48" Height="36"
                            FontSize="14" Foreground="{StaticResource TextMutedBrush}" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="BtnCancel_Click" Margin="348,2,0,2"/>
                </Grid>

                <TextBlock Text="НАЗВАНИЕ" Style="{StaticResource Label}"/>
                <TextBox x:Name="txtName" Style="{StaticResource ModernTextBox}" Margin="0 0 0 16"/>

                <TextBlock Text="ТИП" Style="{StaticResource Label}"/>
                <ComboBox x:Name="cmbType" Height="44" FontSize="15" Margin="0 0 0 16">
                    <ComboBoxItem Content="Расход" IsSelected="True"/>
                    <ComboBoxItem Content="Доход"/>
                </ComboBox>

                <TextBlock Text="ЦВЕТ" Style="{StaticResource Label}"/>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 28">
                    <Border x:Name="colorPreview" Width="48" Height="48" CornerRadius="12" 
                            BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1"/>
                    <TextBox x:Name="txtColor" Style="{StaticResource ModernTextBox}" 
                             Width="140" Margin="14 0 0 0" 
                             Text="#8B5CF6" TextChanged="TxtColor_TextChanged"/>
                    <TextBlock Text="(HEX)" Margin="10 14 0 0" 
                               Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Style="{StaticResource GhostButton}" 
                            Width="120" Margin="0 0 12 0" Click="BtnCancel_Click"/>
                    <Button Content="Добавить" Style="{StaticResource SuccessButton}" 
                            Width="160" Click="BtnSave_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
